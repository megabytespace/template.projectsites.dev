{
  "$schema": "https://schemas.designtokens.org/2025-10",
  "$description": "Applied output — master prompt run against a design / dev studio brief.",

  "business": {
    "name":          { "$value": "Field Studio" },
    "shortName":     { "$value": "Field" },
    "tagline":       { "$value": "Brand · Web · Product" },
    "description":   { "$value": "Independent design studio of 8. Brooklyn + Lisbon. Brand systems + marketing sites for founders and CMOs who care. Booked through Q4." },
    "url":           { "$value": "https://field.example" },
    "businessClass": { "$value": "organization" },
    "email":         { "$value": "hello@field.example" },
    "phone":         { "$value": "" },
    "address":       { "$value": "Brooklyn, NY · Lisbon, PT" },
    "hours":         { "$value": "" }
  },

  "color": {
    "brandHue":    { "$value": "0" },
    "brandChroma": { "$value": "0.22" },
    "primary":     { "$value": "oklch(0.62 {color.brandChroma} {color.brandHue})" },
    "primaryHover":{ "$value": "oklch(0.56 {color.brandChroma} {color.brandHue})" },
    "accent":      { "$value": "oklch(0.85 0.18 60)" },
    "accentHover": { "$value": "oklch(0.78 0.18 60)" },
    "background":  { "$value": "oklch(0.08 0.02 {color.brandHue})" },
    "surface":     { "$value": "oklch(0.12 0.02 {color.brandHue})" },
    "surfaceElevated": { "$value": "oklch(0.16 0.02 {color.brandHue})" },
    "border":      { "$value": "oklch(0.22 0.02 {color.brandHue})" },
    "text":        { "$value": "oklch(0.97 0.005 {color.brandHue})" },
    "textMuted":   { "$value": "oklch(0.65 0.01 {color.brandHue})" },
    "textSubtle":  { "$value": "oklch(0.45 0.01 {color.brandHue})" },
    "success":     { "$value": "oklch(0.74 0.16 152)" },
    "warning":     { "$value": "oklch(0.82 0.16 85)" },
    "danger":      { "$value": "oklch(0.66 0.22 28)" },
    "info":        { "$value": "oklch(0.72 0.15 235)" }
  },

  "colorScheme": { "$value": "dark" },

  "font": {
    "heading":   { "$value": "Archivo Black" },
    "body":      { "$value": "Archivo" },
    "mono":      { "$value": "JetBrains Mono" },
    "weights":   { "$value": [400, 500, 600, 700, 800, 900] },
    "fluidScale":{ "$value": "clamp" }
  },

  "radius":  { "sm": { "$value": "0px" }, "md": { "$value": "0px" }, "lg": { "$value": "0px" }, "xl": { "$value": "0.25rem" }, "2xl": { "$value": "0.5rem" }, "full": { "$value": "9999px" } },
  "spacing": { "0": { "$value": "0" }, "1": { "$value": "0.25rem" }, "2": { "$value": "0.5rem" }, "3": { "$value": "0.75rem" }, "4": { "$value": "1rem" }, "6": { "$value": "1.5rem" }, "8": { "$value": "2rem" }, "12": { "$value": "3rem" }, "16": { "$value": "4rem" }, "24": { "$value": "6rem" }, "32": { "$value": "8rem" } },
  "shadow":  { "sm": { "$value": "0 1px 2px 0 oklch(0 0 0 / 0.05)" }, "md": { "$value": "0 8px 24px -8px oklch(0 0 0 / 0.40)" }, "lg": { "$value": "0 16px 48px -12px oklch(0 0 0 / 0.55)" }, "glow": { "$value": "0 0 40px -8px {color.primary}" } },
  "motion":  { "easing": { "$value": "cubic-bezier(0.4, 0, 0, 1)" }, "duration": { "fast": { "$value": "100ms" }, "base": { "$value": "200ms" }, "slow": { "$value": "350ms" }, "scroll": { "$value": "1000ms" } } },
  "layout":  { "containerWide": { "$value": "80rem" }, "containerNormal": { "$value": "64rem" }, "containerProse": { "$value": "42rem" } },

  "social":  { "facebook": { "$value": "" }, "instagram": { "$value": "https://instagram.com/fieldstudio" }, "linkedin": { "$value": "https://linkedin.com/company/fieldstudio" }, "twitter": { "$value": "https://twitter.com/fieldstudio" }, "youtube": { "$value": "" }, "tiktok": { "$value": "" }, "github": { "$value": "" } },

  "features": {
    "hero":         { "$value": true },
    "bento":        { "$value": false },
    "stats":        { "$value": true },
    "services":     { "$value": true },
    "process":      { "$value": true },
    "testimonials": { "$value": true },
    "logoCloud":    { "$value": true },
    "pricing":      { "$value": false },
    "faq":          { "$value": true },
    "blog":         { "$value": true },
    "team":         { "$value": true },
    "caseStudies":  { "$value": true },
    "newsletter":   { "$value": false },
    "cta":          { "$value": true }
  }
}
