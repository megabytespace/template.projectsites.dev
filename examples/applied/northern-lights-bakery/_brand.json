{
  "$schema": "https://schemas.designtokens.org/2025-10",
  "$description": "Applied output — master prompt run against the Northern Lights Bakery brief.",

  "business": {
    "name":          { "$value": "Northern Lights Bakery" },
    "shortName":     { "$value": "NL Bakery" },
    "tagline":       { "$value": "Sourdough since 1987" },
    "description":   { "$value": "Family-owned Anchorage bakery. Wild-yeast sourdough, almond croissants, seasonal cakes. Open Tue–Sun, 6am–3pm. Walk in or order online." },
    "url":           { "$value": "https://northernlightsbakery.example" },
    "businessClass": { "$value": "restaurant" },
    "email":         { "$value": "hello@northernlightsbakery.example" },
    "phone":         { "$value": "+19075550100" },
    "address":       { "$value": "1234 4th Avenue, Anchorage, AK 99501" },
    "hours":         { "$value": "Tue–Sun 6am–3pm · Closed Mon" }
  },

  "color": {
    "brandHue":    { "$value": "30" },
    "brandChroma": { "$value": "0.22" },
    "primary":     { "$value": "oklch(0.62 {color.brandChroma} {color.brandHue})" },
    "primaryHover":{ "$value": "oklch(0.56 {color.brandChroma} {color.brandHue})" },
    "accent":      { "$value": "oklch(0.62 0.16 145)" },
    "accentHover": { "$value": "oklch(0.55 0.16 145)" },
    "background":  { "$value": "oklch(0.99 0.005 {color.brandHue})" },
    "surface":     { "$value": "oklch(0.97 0.01 {color.brandHue})" },
    "surfaceElevated": { "$value": "oklch(0.94 0.01 {color.brandHue})" },
    "border":      { "$value": "oklch(0.88 0.02 {color.brandHue})" },
    "text":        { "$value": "oklch(0.18 0.02 {color.brandHue})" },
    "textMuted":   { "$value": "oklch(0.42 0.01 {color.brandHue})" },
    "textSubtle":  { "$value": "oklch(0.58 0.01 {color.brandHue})" },
    "success":     { "$value": "oklch(0.55 0.16 152)" },
    "warning":     { "$value": "oklch(0.65 0.16 85)" },
    "danger":      { "$value": "oklch(0.55 0.22 28)" },
    "info":        { "$value": "oklch(0.55 0.15 235)" }
  },

  "colorScheme": { "$value": "light" },

  "font": {
    "heading":   { "$value": "Playfair Display" },
    "body":      { "$value": "Inter" },
    "mono":      { "$value": "JetBrains Mono" },
    "weights":   { "$value": [400, 500, 600, 700, 800] },
    "fluidScale":{ "$value": "clamp" }
  },

  "radius":  { "sm": { "$value": "0.375rem" }, "md": { "$value": "0.75rem" }, "lg": { "$value": "1rem" }, "xl": { "$value": "1.5rem" }, "2xl": { "$value": "2rem" }, "full": { "$value": "9999px" } },
  "spacing": { "0": { "$value": "0" }, "1": { "$value": "0.25rem" }, "2": { "$value": "0.5rem" }, "3": { "$value": "0.75rem" }, "4": { "$value": "1rem" }, "6": { "$value": "1.5rem" }, "8": { "$value": "2rem" }, "12": { "$value": "3rem" }, "16": { "$value": "4rem" }, "24": { "$value": "6rem" }, "32": { "$value": "8rem" } },
  "shadow":  { "sm": { "$value": "0 1px 2px 0 oklch(0 0 0 / 0.05)" }, "md": { "$value": "0 8px 24px -8px oklch(0 0 0 / 0.15)" }, "lg": { "$value": "0 16px 48px -12px oklch(0 0 0 / 0.20)" }, "glow": { "$value": "0 0 40px -8px {color.primary}" } },
  "motion":  { "easing": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)" }, "duration": { "fast": { "$value": "150ms" }, "base": { "$value": "250ms" }, "slow": { "$value": "450ms" }, "scroll": { "$value": "1200ms" } } },
  "layout":  { "containerWide": { "$value": "80rem" }, "containerNormal": { "$value": "64rem" }, "containerProse": { "$value": "42rem" } },

  "social": {
    "facebook":  { "$value": "https://facebook.com/northernlightsbakery" },
    "instagram": { "$value": "https://instagram.com/northernlightsbakery" },
    "linkedin":  { "$value": "" },
    "twitter":   { "$value": "" },
    "youtube":   { "$value": "" },
    "tiktok":    { "$value": "" },
    "github":    { "$value": "" }
  },

  "features": {
    "hero":         { "$value": true },
    "bento":        { "$value": false },
    "stats":        { "$value": false },
    "services":     { "$value": true },
    "process":      { "$value": false },
    "testimonials": { "$value": true },
    "logoCloud":    { "$value": false },
    "pricing":      { "$value": false },
    "faq":          { "$value": true },
    "blog":         { "$value": false },
    "team":         { "$value": false },
    "caseStudies":  { "$value": false },
    "newsletter":   { "$value": true },
    "cta":          { "$value": true }
  }
}
