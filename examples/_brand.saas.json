{
  "$schema": "https://schemas.designtokens.org/2025-10",
  "$description": "SaaS / B2B software preset — indigo, dark, pricing + bento + logoCloud + blog + caseStudies enabled.",

  "business": {
    "name":          { "$value": "Linearity",                              "$type": "string" },
    "shortName":     { "$value": "Linearity",                              "$type": "string" },
    "tagline":       { "$value": "Built for engineers",                    "$type": "string" },
    "description":   { "$value": "The fastest issue tracker for teams who ship. Free until $10K MRR. SOC 2. 50ms p99.", "$type": "string" },
    "url":           { "$value": "https://linearity.example",              "$type": "string" },
    "businessClass": { "$value": "saas",                                   "$type": "string" },
    "email":         { "$value": "hello@linearity.example",                "$type": "string" },
    "phone":         { "$value": "",                                       "$type": "string" },
    "address":       { "$value": "",                                       "$type": "string" },
    "hours":         { "$value": "",                                       "$type": "string" }
  },

  "color": {
    "brandHue":        { "$value": "260", "$type": "number" },
    "brandChroma":     { "$value": "0.20", "$type": "number" },
    "primary":         { "$value": "oklch(0.62 {color.brandChroma} {color.brandHue})", "$type": "color" },
    "primaryHover":    { "$value": "oklch(0.56 {color.brandChroma} {color.brandHue})", "$type": "color" },
    "accent":          { "$value": "oklch(0.82 0.18 165)",                              "$type": "color" },
    "accentHover":     { "$value": "oklch(0.74 0.18 165)",                              "$type": "color" },
    "background":      { "$value": "oklch(0.08 0.02 {color.brandHue})", "$type": "color" },
    "surface":         { "$value": "oklch(0.12 0.02 {color.brandHue})", "$type": "color" },
    "surfaceElevated": { "$value": "oklch(0.16 0.02 {color.brandHue})", "$type": "color" },
    "border":          { "$value": "oklch(0.22 0.02 {color.brandHue})", "$type": "color" },
    "text":            { "$value": "oklch(0.97 0.005 {color.brandHue})", "$type": "color" },
    "textMuted":       { "$value": "oklch(0.65 0.01 {color.brandHue})",  "$type": "color" },
    "textSubtle":      { "$value": "oklch(0.45 0.01 {color.brandHue})",  "$type": "color" },
    "success":         { "$value": "oklch(0.74 0.16 152)", "$type": "color" },
    "warning":         { "$value": "oklch(0.82 0.16 85)",  "$type": "color" },
    "danger":          { "$value": "oklch(0.66 0.22 28)",  "$type": "color" },
    "info":            { "$value": "oklch(0.72 0.15 235)", "$type": "color" }
  },

  "colorScheme": { "$value": "dark", "$type": "string" },

  "font": {
    "heading":   { "$value": "Inter Tight",   "$type": "fontFamily" },
    "body":      { "$value": "Inter",         "$type": "fontFamily" },
    "mono":      { "$value": "JetBrains Mono","$type": "fontFamily" },
    "weights":   { "$value": [400,500,600,700,800], "$type": "fontWeight" },
    "fluidScale":{ "$value": "clamp", "$type": "string" }
  },

  "radius":  { "sm": { "$value": "0.375rem", "$type": "dimension" }, "md": { "$value": "0.5rem", "$type": "dimension" }, "lg": { "$value": "0.75rem", "$type": "dimension" }, "xl": { "$value": "1rem", "$type": "dimension" }, "2xl": { "$value": "1.5rem", "$type": "dimension" }, "full": { "$value": "9999px", "$type": "dimension" } },
  "spacing": { "0": { "$value": "0", "$type": "dimension" }, "1": { "$value": "0.25rem", "$type": "dimension" }, "2": { "$value": "0.5rem", "$type": "dimension" }, "3": { "$value": "0.75rem", "$type": "dimension" }, "4": { "$value": "1rem", "$type": "dimension" }, "6": { "$value": "1.5rem", "$type": "dimension" }, "8": { "$value": "2rem", "$type": "dimension" }, "12": { "$value": "3rem", "$type": "dimension" }, "16": { "$value": "4rem", "$type": "dimension" }, "24": { "$value": "6rem", "$type": "dimension" }, "32": { "$value": "8rem", "$type": "dimension" } },
  "shadow":  { "sm": { "$value": "0 1px 2px 0 oklch(0 0 0 / 0.05)", "$type": "shadow" }, "md": { "$value": "0 8px 24px -8px oklch(0 0 0 / 0.40)", "$type": "shadow" }, "lg": { "$value": "0 16px 48px -12px oklch(0 0 0 / 0.55)", "$type": "shadow" }, "glow": { "$value": "0 0 40px -8px {color.primary}", "$type": "shadow" } },
  "motion":  { "easing": { "$value": "cubic-bezier(0.16, 1, 0.3, 1)", "$type": "cubicBezier" }, "duration": { "fast": { "$value": "150ms", "$type": "duration" }, "base": { "$value": "250ms", "$type": "duration" }, "slow": { "$value": "450ms", "$type": "duration" }, "scroll": { "$value": "1200ms", "$type": "duration" } } },
  "layout":  { "containerWide": { "$value": "80rem", "$type": "dimension" }, "containerNormal": { "$value": "64rem", "$type": "dimension" }, "containerProse": { "$value": "42rem", "$type": "dimension" } },
  "social":  { "facebook": { "$value": "", "$type": "string" }, "instagram": { "$value": "", "$type": "string" }, "linkedin": { "$value": "", "$type": "string" }, "twitter": { "$value": "", "$type": "string" }, "youtube": { "$value": "", "$type": "string" }, "tiktok": { "$value": "", "$type": "string" }, "github": { "$value": "", "$type": "string" } },

  "features": {
    "hero":         { "$value": true,  "$type": "boolean" },
    "bento":        { "$value": true,  "$type": "boolean" },
    "stats":        { "$value": true,  "$type": "boolean" },
    "services":     { "$value": false, "$type": "boolean" },
    "process":      { "$value": false, "$type": "boolean" },
    "testimonials": { "$value": true,  "$type": "boolean" },
    "logoCloud":    { "$value": true,  "$type": "boolean" },
    "pricing":      { "$value": true,  "$type": "boolean" },
    "faq":          { "$value": true,  "$type": "boolean" },
    "blog":         { "$value": true,  "$type": "boolean" },
    "team":         { "$value": false, "$type": "boolean" },
    "caseStudies":  { "$value": true,  "$type": "boolean" },
    "newsletter":   { "$value": true,  "$type": "boolean" },
    "cta":          { "$value": true,  "$type": "boolean" }
  }
}
